DATABASE_URL=postgresql://user:password@localhost:5432/qauto
REDIS_URL=redis://localhost:6379
GROQ_API_KEY=your_groq_api_key_here
SENTRY_DSN=
ENVIRONMENT=local

# PostgreSQL (required). Use %40 for @ in password.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/qauto
# Or use discrete vars: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD

# Redis (optional but recommended for production). In-memory cache used if unset.
# REDIS_URL=redis://localhost:6379

# Groq API for AI Advisor chat (required for AI replies).
# GROQ_API_KEY=your_groq_api_key
